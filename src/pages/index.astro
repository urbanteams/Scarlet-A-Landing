---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="min-h-screen bg-[#050505] selection:bg-[#DC2626] selection:text-white">

    <!-- Global Noise Overlay -->
    <div class="noise-overlay"></div>

    <!-- ─────────────── Navigation ─────────────── -->
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 py-8">
      <div class="container mx-auto px-6 flex items-center justify-between">
        <a href="#" class="text-4xl font-cursive" style="letter-spacing: 0.01em;">
          Scarlet <span style="color: var(--color-accent);">A</span> Games
        </a>

        <div class="hidden md:flex items-center space-x-8">
          <a href="#mission" class="text-sm text-gray-400 hover:text-white transition-colors duration-300">Mission</a>
          <a href="#experiences" class="text-sm text-gray-400 hover:text-white transition-colors duration-300">Experiences</a>
        </div>

        <a href="#contact" class="inline-flex items-center justify-center px-6 py-3 rounded-full text-sm font-medium bg-white text-black hover:scale-105 hover:bg-gray-100 transition-all duration-300">
          Play Now
        </a>
      </div>
    </nav>

    <!-- ─────────────── Hero ─────────────── -->
    <section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-32 pb-20 bg-[#050505]">

      <!-- Atmospheric gradient backdrop -->
      <div class="absolute inset-0 z-0 pointer-events-none select-none">
        <div class="absolute top-[-20%] left-[10%] w-[80vw] h-[80vw] rounded-full opacity-[0.12]"
             style="background: radial-gradient(circle, #DC2626 0%, transparent 70%); max-width: 900px; max-height: 900px;"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#050505] z-10"></div>
      </div>

      <!-- Left decorative orb -->
      <div class="absolute -left-[8%] top-[8%] w-[38vw] max-w-[520px] z-10 pointer-events-none orb-left" aria-hidden="true">
        <div class="pulse-ring absolute inset-0 rounded-full"
             style="background: radial-gradient(circle, rgba(220,38,38,0.18) 0%, transparent 70%); transform: scale(1.3);"></div>
        <div style="aspect-ratio:1; background: radial-gradient(circle at 35% 30%, rgba(220,38,38,0.55) 0%, rgba(185,28,28,0.25) 40%, transparent 70%); border-radius: 50%; filter: blur(2px);"></div>
      </div>

      <!-- Right decorative orb -->
      <div class="absolute -right-[8%] bottom-[5%] w-[32vw] max-w-[440px] z-10 pointer-events-none orb-right" aria-hidden="true">
        <div class="pulse-ring absolute inset-0 rounded-full"
             style="background: radial-gradient(circle, rgba(100,100,140,0.15) 0%, transparent 70%); transform: scale(1.25); animation-delay: 3s;"></div>
        <div style="aspect-ratio:1; background: radial-gradient(circle at 60% 65%, rgba(80,80,120,0.4) 0%, rgba(40,40,80,0.15) 45%, transparent 70%); border-radius: 50%; filter: blur(3px);"></div>
      </div>

      <!-- Hero Content -->
      <div class="container mx-auto px-6 relative z-20 text-center flex flex-col items-center justify-center">
        <div id="hero-content-wrapper" class="max-w-4xl mx-auto">

          <div class="reveal">
            <h1 class="leading-tight mb-6"
                style="color: #ffe0e0; mix-blend-mode: overlay; text-shadow: 0 0 14px rgba(255,255,255,0.65);">
              <span class="font-cursive block" style="font-size: clamp(3.5rem, 7vw, 6rem); line-height: 1.05;">Scarlet <span style="color: var(--color-accent);">A</span> Games</span>
              <span class="block mt-1 font-serif italic font-normal" style="font-size: clamp(2.6rem, 5.2vw, 4.6rem); line-height: 1.1; opacity: 0.92;">Bold games for bold players.</span>
            </h1>
          </div>

          <div class="reveal" style="transition-delay: 200ms;">
            <p class="text-base md:text-lg max-w-lg mx-auto mb-16 font-light tracking-wide leading-relaxed"
               style="color: rgba(255,224,224,0.88); mix-blend-mode: overlay; text-shadow: 0 0 12px rgba(255,255,255,0.6);">
              We create arenas for you to have legendary moments. The flow state awaits.
            </p>
          </div>

          <div class="reveal flex flex-col items-center gap-6" style="transition-delay: 400ms;">
            <div class="relative glow-btn group cursor-pointer">
              <div class="relative border border-white/20 bg-white/5 backdrop-blur-sm px-6 py-2 rounded-full flex items-center gap-3 text-xs md:text-sm text-white/80 uppercase tracking-widest hover:bg-white/10 transition-colors duration-300">
                <span>Play Now</span>
              </div>
            </div>

            <div class="flex items-center gap-4 text-[10px] md:text-xs text-white/40 uppercase tracking-widest mt-8 font-mono">
              <span>Est. 2026</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─────────────── Mission Section ─────────────── -->
    <section id="mission" class="py-32 relative">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center reveal">
          <h2 class="text-3xl md:text-5xl lg:text-6xl leading-tight text-white/90 mb-12 font-serif">
            We design games and experiences that aren't afraid to challenge you.
          </h2>
          <p class="text-xl md:text-2xl text-gray-500 leading-relaxed font-light">
            No dopamine loops. No brainrot. Just games that are easy to learn, yet take a lifetime to master.
          </p>
        </div>
        <!-- Accolades / Trust Markers -->
        <div class="mt-32 grid grid-cols-2 md:grid-cols-4 gap-8 items-center justify-items-center opacity-35 grayscale hover:grayscale-0 hover:opacity-70 transition-all duration-700">
          <div class="reveal font-bold text-sm tracking-widest text-center">PAYOLA<br/><span class="font-normal text-xs">Bidding, negotiation, area control</span></div>
          <div class="reveal font-bold text-sm tracking-widest text-center" style="transition-delay: 100ms;">BLACK AND RED<br/><span class="font-normal text-xs">A game of pure psychology</span></div>
          <div class="reveal font-bold text-sm tracking-widest text-center" style="transition-delay: 200ms;">THE SCARLET TRIANGLE<br/><span class="font-normal text-xs">A strategy game of covering your bases</span></div>
          <div class="reveal font-bold text-sm tracking-widest text-center" style="transition-delay: 300ms;">TARGET NUMBER<br/><span class="font-normal text-xs">Memory with a pinch of math</span></div>
        </div>
      </div>
    </section>

    <!-- ─────────────── Catalog / Cards Section ─────────────── -->
    <section id="experiences" class="py-40 relative overflow-hidden">
      <div class="container mx-auto px-6 relative z-10">
        <div class="reveal mb-32">
          <h2 class="text-5xl md:text-7xl text-center font-serif">
            Experiences that<br />
            <span class="font-cursive" style="font-size: 0.82em; line-height: 1.2;">make their mark.</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">

          <!-- Card 1 — Live Events -->
          <div class="parallax-card-down">
            <div class="reveal rounded-3xl p-8 md:p-12 aspect-[4/5] flex flex-col justify-between shadow-2xl transition-all duration-500 group cursor-pointer"
                 style="background-color: var(--color-accent); box-shadow: 0 20px 50px rgba(220,38,38,0.15);"
                 data-card="scarlet">
              <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-full bg-black/10 flex items-center justify-center group-hover:rotate-45 transition-transform duration-500">
                  <iconify-icon icon="lucide:star" class="text-black text-2xl"></iconify-icon>
                </div>
                <span class="text-black font-medium text-sm border border-black/20 px-3 py-1 rounded-full">01</span>
              </div>

              <div>
                <h3 class="text-4xl md:text-5xl text-black mb-4 leading-none tracking-tight font-serif">
                  Live<br />Events
                </h3>
                <p class="text-black/70 text-lg leading-snug">
                  You've never played a game of Mafia or Werewolf like this. Coming Summer 2026 to Vancouver, BC.
                </p>
              </div>

              <div class="w-full h-px bg-black/10 mt-8"></div>
            </div>
          </div>

          <!-- Card 2 — Online Reality Games -->
          <div class="parallax-card-up md:mt-24">
            <div class="reveal bg-[#111] border border-white/10 rounded-3xl p-8 md:p-12 aspect-[4/5] flex flex-col justify-between shadow-2xl group cursor-pointer transition-all duration-500"
                 style="transition-delay: 150ms;"
                 data-card="dark">
              <div class="flex justify-between items-start">
                <div class="w-12 h-12 rounded-full bg-white/5 flex items-center justify-center group-hover:scale-110 transition-transform duration-500">
                  <iconify-icon icon="lucide:arrow-right" class="text-white text-2xl -rotate-45"></iconify-icon>
                </div>
                <span class="text-white/50 font-medium text-sm border border-white/10 px-3 py-1 rounded-full">02</span>
              </div>

              <div>
                <h3 class="text-4xl md:text-5xl text-white mb-4 leading-none tracking-tight font-serif">
                  Online Reality<br />Games
                </h3>
                <p class="text-gray-400 text-lg leading-snug">
                  From the creator of the acclaimed Reality Labs series, something new. Stay tuned.
                </p>
              </div>

              <div class="w-full h-px bg-white/10 mt-8"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Background dot grid -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] opacity-10 pointer-events-none"
           style="background-image: radial-gradient(circle, #333 1px, transparent 1px); background-size: 40px 40px;"></div>
    </section>

    <!-- ─────────────── Footer ─────────────── -->
    <footer id="contact" class="py-20 bg-[#050505] relative overflow-hidden" style="border-top: 1px solid rgba(255,255,255,0.05);">
      <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-12">
          <div class="w-full md:w-auto">
            <h2 class="leading-[0.85] text-white/10 select-none pointer-events-none font-cursive"
                style="font-size: 12vw;">
              Scarlet A Games
            </h2>
          </div>

          <div class="flex flex-col gap-8 text-right">
            <div class="flex flex-col gap-4 text-gray-400">
              <a href="#" class="hover:text-white transition-colors duration-300">Discord</a>
              <a href="#" class="hover:text-white transition-colors duration-300">Instagram</a>
              <a href="#" class="hover:text-white transition-colors duration-300">Twitter / X</a>
              <a href="#" class="hover:text-white transition-colors duration-300">LinkedIn</a>
            </div>
            <p class="text-sm text-gray-600">&copy; 2025 Scarlet A Games. All rights reserved.</p>
          </div>
        </div>
      </div>
    </footer>

  </div>

  <script>
    // 1. Reveal on scroll
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('active');
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

    // 2. Navbar scroll shrink
    const nav = document.getElementById('main-nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav?.classList.add('py-4', 'backdrop-blur-md', 'border-b');
        if (nav) nav.style.cssText += 'background-color: rgba(5,5,5,0.82); border-bottom-color: rgba(255,255,255,0.05);';
        nav?.classList.remove('py-8');
      } else {
        nav?.classList.remove('py-4', 'backdrop-blur-md', 'border-b');
        if (nav) {
          nav.style.backgroundColor = '';
          nav.style.borderBottom = '';
        }
        nav?.classList.add('py-8');
      }
    });

    // 3. Parallax cards
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      document.querySelectorAll('.parallax-card-up').forEach(el => {
        (el as HTMLElement).style.setProperty('--scroll-offset-up', `${scrolled * -0.05}px`);
      });
      document.querySelectorAll('.parallax-card-down').forEach(el => {
        (el as HTMLElement).style.setProperty('--scroll-offset-down', `${scrolled * 0.05}px`);
      });
    });

    // 4. Card hover effects
    document.querySelector('[data-card="scarlet"]')?.addEventListener('mouseenter', function(this: HTMLElement) {
      this.style.boxShadow = '0 20px 60px rgba(220,38,38,0.35)';
    });
    document.querySelector('[data-card="scarlet"]')?.addEventListener('mouseleave', function(this: HTMLElement) {
      this.style.boxShadow = '0 20px 50px rgba(220,38,38,0.15)';
    });
    document.querySelector('[data-card="dark"]')?.addEventListener('mouseenter', function(this: HTMLElement) {
      this.style.borderColor = 'rgba(220,38,38,0.4)';
    });
    document.querySelector('[data-card="dark"]')?.addEventListener('mouseleave', function(this: HTMLElement) {
      this.style.borderColor = 'rgba(255,255,255,0.10)';
    });

    // 5. Hero parallax fade
    const heroWrapper = document.getElementById('hero-content-wrapper');
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      if (heroWrapper && scrolled < 1000) {
        heroWrapper.style.transform = `translateY(${scrolled * 0.4}px)`;
        heroWrapper.style.opacity = String(Math.max(0, 1 - scrolled / 600));
      }
    });
  </script>
</Layout>
